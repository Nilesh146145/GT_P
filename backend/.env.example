# Copy to backend/.env and/or repo-root .env (both are loaded; backend/.env overrides).
#
# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=sow_generator
# Timeouts (ms) — avoid hanging forever on Atlas/network; important on Render
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_CONNECT_TIMEOUT_MS=10000
# With the API running on 8001, verify DB + HTTP:  bash scripts/check_api_health.sh

# ── JWT / Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MFA (TOTP) ─────────────────────────────────────────────────────────────────
TOTP_ISSUER=GlimmoraTeam
MFA_PENDING_TOKEN_MINUTES=10
MFA_SETUP_PENDING_MINUTES=15
# Optional: base64-encoded 32-byte key (preferred in production). If unset, derived from SECRET_KEY.
TOTP_ENCRYPTION_KEY=
TOTP_KEY_ID=app-v1
MFA_RECOVERY_CODE_COUNT=10
MFA_VERIFY_MAX_ATTEMPTS_PER_MINUTE=5
MFA_RECOVERY_MAX_ATTEMPTS_PER_HOUR=10
# Optional Redis URL for distributed MFA rate limiting
REDIS_URL=

# ── NextAuth compatibility ────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in your Next.js .env
NEXTAUTH_SECRET=your-nextauth-secret

# ── OAuth / SSO ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# If the API is behind a reverse proxy, set public origin (no trailing slash) so OAuth redirect_uri matches IdP config
# OAUTH_PUBLIC_BASE_URL=https://api.yourdomain.com
# Azure: common | organizations | <tenant-guid>
MICROSOFT_TENANT_ID=common
# Callback paths (register these in Google Cloud + Azure):
#   {OAUTH_PUBLIC_BASE_URL or your server}/api/v1/auth/oauth/google/callback
#   {OAUTH_PUBLIC_BASE_URL or your server}/api/v1/auth/oauth/microsoft/callback

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
# Set to False in production and wire a real SMS/email gateway
OTP_DRY_RUN=True

# ── Platform ──────────────────────────────────────────────────────────────────
MIN_BUDGET_INR=500000
MIN_BUDGET_USD=6000
REVIEWER_API_ENABLED=true
# Exposes /api/v1/billing/* in Swagger; set false to hide billing routes
BILLING_API_ENABLED=true

# Optional: Planning §8 — when set, AGI (or ops) can POST
# /api/v1/internal/decomposition/plans/{plan_id}/revision/complete
# with header X-GT-Decomposition-Webhook-Secret to exit REVISION_IN_PROGRESS.
DECOMPOSITION_REVISION_WEBHOOK_SECRET=

# ── Render / PaaS hosting ────────────────────────────────────────────────────
# Render injects $PORT — do not hardcode a port in production.
# Start command (example):
#   uvicorn app.main:app --host 0.0.0.0 --port $PORT
# Set Health Check Path in Render to /health or / (GET or HEAD both work after deploy).

# ── OpenAI (Manual SOW — Section C) ───────────────────────────────────────────
# When Section A+B are valid, GET /api/v1/sow/{id}/commercial-details auto-generates
# and returns aiGeneratedText in that same JSON response (requires this key unless mock flags below).
#
# Put the real key ONLY in backend/.env (gitignored). Do NOT paste secrets into this file —
# .env.example is a template and is often committed to Git.
OPENAI_API_KEY=
MANUAL_SOW_OPENAI_MODEL=gpt-4o-mini
# insufficient_quota / no billing: https://platform.openai.com/account/billing
# Local/demo without paid API: skip OpenAI entirely (deterministic payload from commercial_details)
MANUAL_SOW_USE_MOCK_AI_TECH_STACK=false
# Default true: on insufficient_quota, same GET persists a mock AI block so aiGeneratedText is not stuck null.
# Set to false if you must not store mock data when billing fails.
MANUAL_SOW_AI_FALLBACK_ON_QUOTA=true
# When true, OpenAI tech-stack work runs in the background; poll GET /sow/{id}/commercial-details until aiGeneratedText fills in.
MANUAL_SOW_AI_TECH_STACK_ASYNC=false
