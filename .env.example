# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=sow_generator
# Timeouts (ms) — avoid hanging forever on Atlas/network; important on Render
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_CONNECT_TIMEOUT_MS=10000

# ── JWT / Auth ────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── MFA (TOTP) ─────────────────────────────────────────────────────────────────
TOTP_ISSUER=GlimmoraTeam
MFA_PENDING_TOKEN_MINUTES=10
MFA_SETUP_PENDING_MINUTES=15
# Optional: base64-encoded 32-byte key (preferred in production). If unset, derived from SECRET_KEY.
TOTP_ENCRYPTION_KEY=
TOTP_KEY_ID=app-v1
MFA_RECOVERY_CODE_COUNT=10
MFA_VERIFY_MAX_ATTEMPTS_PER_MINUTE=5
MFA_RECOVERY_MAX_ATTEMPTS_PER_HOUR=10
# Optional Redis URL for distributed MFA rate limiting
REDIS_URL=

# ── NextAuth compatibility ────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in your Next.js .env
NEXTAUTH_SECRET=your-nextauth-secret

# ── OAuth / SSO ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# If the API is behind a reverse proxy, set public origin (no trailing slash) so OAuth redirect_uri matches IdP config
# OAUTH_PUBLIC_BASE_URL=https://api.yourdomain.com
# Azure: common | organizations | <tenant-guid>
MICROSOFT_TENANT_ID=common
# Callback paths (register these in Google Cloud + Azure):
#   {OAUTH_PUBLIC_BASE_URL or your server}/api/v1/auth/oauth/google/callback
#   {OAUTH_PUBLIC_BASE_URL or your server}/api/v1/auth/oauth/microsoft/callback

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
# Set to False in production and wire a real SMS/email gateway
OTP_DRY_RUN=True

# ── Platform ──────────────────────────────────────────────────────────────────
MIN_BUDGET_INR=500000
MIN_BUDGET_USD=6000
REVIEWER_API_ENABLED=true

# ── Render / PaaS hosting ────────────────────────────────────────────────────
# Render injects $PORT — do not hardcode a port in production.
# Start command (example):
#   uvicorn app.main:app --host 0.0.0.0 --port $PORT
# Set Health Check Path in Render to /health or / (GET or HEAD both work after deploy).
